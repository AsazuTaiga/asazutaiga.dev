---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDisplayTitle } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const slug = Astro.params.slug;
if (!slug) {
  throw new Error('Missing slug param for notes detail page.');
}

const post = await getEntry('posts', slug);
if (!post) {
  return Astro.redirect('/notes', 302);
}

const { Content } = await render(post);
const displayTitle = getDisplayTitle(post.data.title, post.data.archived);
const ogImage = `/og/${post.id}.png`;
---

<BaseLayout
  title={`${displayTitle} | asazutaiga.dev`}
  description={post.data.title}
  ogTitle={post.data.title}
  ogType="article"
  ogImage={ogImage}
>
  <article class="article">
    <p class="post-date">{post.data.createdAt}</p>
    <h1>{displayTitle}</h1>
    {post.data.archived && (
      <p class="archive-note">
        Archived: 旧ブログから移行した記事です。内容が古い可能性があります。
      </p>
    )}
    <Content />
  </article>

  <p class="back-link-wrap">
    <a class="back-link" href="/notes">← Back to notes</a>
  </p>
</BaseLayout>
