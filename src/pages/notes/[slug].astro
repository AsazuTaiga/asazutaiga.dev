---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const slug = Astro.params.slug;
if (!slug) {
  throw new Error('Missing slug param for notes detail page.');
}

const post = await getEntry('posts', slug);
if (!post) {
  return Astro.redirect('/notes', 302);
}

const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | asazutaiga.dev`} description={post.data.title}>
  <article class="article">
    <p class="post-date">{post.data.createdAt}</p>
    <h1>{post.data.title}</h1>
    <Content />
  </article>

  <p class="back-link-wrap">
    <a class="back-link" href="/notes">← Back to notes</a>
  </p>
</BaseLayout>
